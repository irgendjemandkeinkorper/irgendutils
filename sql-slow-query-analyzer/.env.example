# Password for the READ-ONLY database user (variable name is set by db.pass_env in config.yml).
# The user should only have SELECT + PROCESS grants. Never use a read-write account.
DB_RO_PASSWORD=change-me

# Optional: disable ANSI colors in console output.
# NO_COLOR=1

# Test/dev hook: path to a JSON fixture (see fixtures/db.fixture.json) that makes the
# CLI use the offline fake DB adapter instead of a live connection. Not for production.
# SLOWQ_FAKE_DB_FIXTURE=fixtures/db.fixture.json
