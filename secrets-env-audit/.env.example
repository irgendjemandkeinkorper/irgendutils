# Environment variables read by secaudit itself.
# Copy to .env and source it (secaudit does not auto-load this file).
# Secrets never live in config.yml — but secaudit itself needs none;
# these are optional behavior overrides only.

# Path to the config file (overridden by --config)
SECAUDIT_CONFIG=config.yml

# Directory reports are written to (overridden by --out). Reports are
# sensitive (they list WHERE secrets live) — point this somewhere private.
SECAUDIT_OUT_DIR=report

# Set to any value to disable ANSI colors (standard convention)
NO_COLOR=
