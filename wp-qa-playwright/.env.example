# WP Application Password used for authenticated WP-hygiene checks.
# The variable NAME is whatever `auth.app_password_env` in qa.config.yml points at
# (default shown here). Only ever sent as Basic auth over HTTPS. Never logged.
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Set to any value to disable ANSI colors in CLI output (standard convention).
# NO_COLOR=1
