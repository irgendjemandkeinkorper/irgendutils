# Password for the read-only DB user used by `charset scan` / `charset ddl`.
# The variable NAME is configurable via `db.pass_env` in config.yml.
DB_RO_PASSWORD=change-me

# Password for a user with ALTER privilege, used only by `charset convert --apply`.
# The variable NAME is configurable via `db.apply_pass_env` in config.yml
# (falls back to db.pass_env / DB_RO_PASSWORD if unset).
DB_RW_PASSWORD=change-me
