# WordPress REST API target (used by --push / --media import with wp.mode=rest)
WP_BASE_URL=https://example.com
WP_USER=admin
# Application Password (WP admin > Users > Profile > Application Passwords). Never commit the real one.
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# WP-CLI target (used with wp.mode=wpcli)
WP_CLI_BIN=wp
WP_PATH=/var/www/example

# Optional: base URL used to resolve relative asset URLs in the input HTML
H2G_MEDIA_BASE=https://example.com

# Optional: Playwright storage state JSON for a logged-in editor session (h2g verify)
PLAYWRIGHT_STORAGE_STATE=./storage-state.json
