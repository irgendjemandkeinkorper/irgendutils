# Webhook URL for the "webhook" alert channel (POSTed a JSON payload per new alert batch).
# Leave empty to disable webhook delivery.
MONITOR_WEBHOOK_URL=

# Address printed in the "email" alert channel stub. Actual email delivery is left
# to your notifier (pipe the alert lines / webhook payload into it).
MONITOR_ALERT_EMAIL=ops@example.com

# --- Testing / development only ---
# Path to an ESM module exporting an adapters object (or factory). When set, the CLI
# uses it instead of the live network adapters, so runs are fully offline.
MONITOR_ADAPTERS=

# JSON fixture file consumed by fixtures/fake-adapters.js when used as MONITOR_ADAPTERS.
MONITOR_FIXTURE_FILE=
