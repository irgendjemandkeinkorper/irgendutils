# WordPress Application Password for the REST user named in config.yml
# (rest.user). The config names WHICH env var to read via
# rest.app_password_env — this is the default name.
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Only needed when dns.provider: cloudflare
CLOUDFLARE_API_TOKEN=cf-api-token-here

# Only needed when dns.provider: route53 (used by the aws CLI the adapter
# shells out to; a configured ~/.aws/credentials profile works too)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Optional: where run logs are written (default: ./runs)
# SPINUP_LOG_DIR=./runs
