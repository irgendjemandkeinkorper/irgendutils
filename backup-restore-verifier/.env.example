# Admin password for the MySQL server that hosts the scratch verify_<ts> databases.
# The variable NAME must match scratch.mysql_admin_env in config.yml.
# Passed to mysql via the MYSQL_PWD environment variable — never on the command line,
# never logged, never stored in config.
MYSQL_ADMIN_PW=changeme

# Optional: disable ANSI colors in CLI output
# NO_COLOR=1
